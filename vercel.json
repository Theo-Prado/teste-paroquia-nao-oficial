{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "other",
  "functions": {
    "api/**/*.ts": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "outputDirectory": "dist/client"
}
